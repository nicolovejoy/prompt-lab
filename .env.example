# Required for nightly synthesis (synthesizer.py) and review emails (send-review.py)
export ANTHROPIC_API_KEY=sk-ant-...

# Required for review emails only — omit these to skip email entirely
export RESEND_API_KEY=re_...
export REVIEW_FROM_EMAIL=reviews@yourdomain.com
export REVIEW_TO_EMAIL=you@example.com

# Optional: Turso remote sync (for cloud dashboard and mobile access)
# See: turso db create promptlab && turso db show promptlab --url
# export TURSO_DATABASE_URL=libsql://promptlab-<your-org>.turso.io
# export TURSO_AUTH_TOKEN=<token from: turso db tokens create promptlab>

# Optional: Cloud dashboard auth (set in Vercel env vars for deployment)
# export AUTH_SECRET=<password for cloud dashboard login>
