{
  "build": {
    "env": {
      "PYTHONPATH": "api"
    }
  },
  "functions": {
    "api/**/*.py": {
      "includeFiles": "api/_*.py"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
